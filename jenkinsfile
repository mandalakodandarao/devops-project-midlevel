pipeline {
    agent any

    environment {
        DOCKER_REPO = "mandalakodandarao"
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Build Jars') {
            steps {
                sh '''
                cd api-gateway && mvn clean package
                cd ../user-service && mvn clean package
                cd ../order-service && mvn clean package
                cd ../payment-service && mvn clean package
                '''
            }
        }
        stage('Build Images') {
            steps {
                    sh '''
                docker build -t <dockerhub-username>/api-gateway:latest Dockerfile/api-gateway_docfile
                docker build -t <dockerhub-username>/user-service:latest Dockerfile/user-service_docfile
                docker build -t <dockerhub-username>/order-service:latest Dockerfile/order-service_docfile
                docker build -t <dockerhub-username>/payment-service:latest Dockerfile/payment-service_docfile
                '''
    }
}

        stage('Push Images') {
            steps {                sh '''
                docker push $DOCKER_REPO/frontend:${BUILD_NUMBER}
                docker push $DOCKER_REPO/api-gateway:${BUILD_NUMBER}
                docker push $DOCKER_REPO/user-service:${BUILD_NUMBER}
                docker push $DOCKER_REPO/order-service:${BUILD_NUMBER}
                docker push $DOCKER_REPO/payment-service:${BUILD_NUMBER}
                '''
            }
        }

        stage('Deploy') {
            steps {
                sh '''
                kubectl apply -f k8s/
                '''
            }
        }
    }
}
